{
  "name": "puebloladehesa-rediseno",
  "version": "0.1.0",
  "description": "Rediseño de puebloladehesa.cl con Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "setup": "bash scripts/setup.sh",
    "extract": "python3 scripts/extract_content.py",
    "optimize-images": "node scripts/optimize_images.mjs",
    "import-content": "node scripts/import_content.mjs",
    "test:smoke": "node scripts/smoke_test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write ."
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "typescript": "5.5.4",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "tailwindcss": "3.4.7",
    "postcss": "8.4.40",
    "autoprefixer": "10.4.19",
    "sharp": "0.33.4",
    "@playwright/test": "1.46.1",
    "eslint": "8.57.0",
    "eslint-config-next": "14.2.15",
    "prettier": "3.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
