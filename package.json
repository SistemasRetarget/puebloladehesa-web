{
  "name": "puebloladehesa-rediseno",
  "version": "0.1.0",
  "description": "Rediseño de puebloladehesa.cl con Next.js",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "setup": "bash scripts/setup.sh",
    "extract": "python3 scripts/extract_content.py",
    "optimize-images": "node scripts/optimize_images.mjs",
    "import-content": "node scripts/import_content.mjs",
    "test:smoke": "node scripts/smoke_test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "seed": "node scripts/seed-rest.mjs",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap"
  },
  "dependencies": {
    "@payloadcms/db-sqlite": "^3.83.0",
    "@payloadcms/next": "^3.83.0",
    "@payloadcms/richtext-lexical": "^3.83.0",
    "@payloadcms/ui": "^3.83.0",
    "graphql": "^16.13.2",
    "next": "~15.4.11",
    "payload": "^3.83.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "20.14.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "10.4.19",
    "better-sqlite3": "^12.9.0",
    "cross-env": "^7.0.3",
    "eslint": "8.57.0",
    "eslint-config-next": "~15.4.11",
    "postcss": "8.4.40",
    "prettier": "3.3.3",
    "sass": "^1.99.0",
    "sharp": "0.33.4",
    "tailwindcss": "3.4.7",
    "tsx": "^4.21.0",
    "typescript": "5.5.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
