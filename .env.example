# --- Reservas ---
NEXT_PUBLIC_BOOKING_URL=https://puebloladehesa.book2dream.com/

# --- Contacto ---
NEXT_PUBLIC_WHATSAPP_NUMBER=56984148269
NEXT_PUBLIC_CONTACT_EMAIL=contacto@puebloladehesa.cl
NEXT_PUBLIC_ADDRESS=Av. Santa Blanca 550, Lo Barnechea, Chile

# --- Tracking (Consent Mode v2) ---
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# --- reCAPTCHA (form de contacto) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
